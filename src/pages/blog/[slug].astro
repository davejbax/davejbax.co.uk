---
import Default from '../../layouts/Default.astro';
import PostToc from '../../components/PostToc.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readTime = readingTime(post.body);
const windowTitle = `blog/${post.data.date}-${post.id}.md · Dave Baxter`;
---

<Default
  title={`${post.data.title} · Dave Baxter`}
  windowTitle={windowTitle}
  variant="post"
>
  <PostToc slot="sidebar" headings={headings} readTime={readTime} />

  <div class="post-content">
    <p class="post-meta">{post.data.date} &centerdot; {readTime} read</p>
    <h1 class="post-title">{post.data.title}</h1>
    <div class="post-body">
      <Content />
    </div>
  </div>
</Default>

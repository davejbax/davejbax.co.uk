---
import Nav from '../components/Nav.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.scss';
import { Font } from 'astro:assets';

interface Props {
  title: string;
  windowTitle?: string;
  variant?: 'post';
}

const { title, windowTitle, variant } = Astro.props;
const isPost = variant === 'post';
---

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE-edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{title}</title>

  <Font cssVariable='--font-mono' preload />
  <Font cssVariable='--font-serif' />

  <ClientRouter />

  <!--
  Do color settings in the head, so that the user doesn't get a flash of their original color setting
   before it switches to the alternative one.
   All other scripts are in the footer, since they're not as critical as this.
  -->
  <script is:inline>
    /** CSS class name for turning alternative color on */
    const COLOR_ALT_CLASS = 'color-alt';

    /** Local storage key for the alternative color setting */
    const LOCAL_STORAGE_COLOR_ALT = 'use-alternative-color';

    const setAlternativeColor = (enabled) => {
      const classList = document.documentElement.classList;

      classList.toggle(COLOR_ALT_CLASS, enabled);
      localStorage.setItem(LOCAL_STORAGE_COLOR_ALT, classList.contains(COLOR_ALT_CLASS) ? 'yes' : 'no');
    }

    // Set the current color now in the head so we don't get a flash of the wrong color
    if (localStorage.getItem(LOCAL_STORAGE_COLOR_ALT) !== null && localStorage.getItem(LOCAL_STORAGE_COLOR_ALT) === 'yes') {
      setAlternativeColor(true);
    }

    // The color class gets unapplied by the Astro ClientRouter. We need to reapply it on every page load.
    document.addEventListener('astro:page-load', () => {
      if (localStorage.getItem(LOCAL_STORAGE_COLOR_ALT) !== null && localStorage.getItem(LOCAL_STORAGE_COLOR_ALT) === 'yes') {
        setAlternativeColor(true);
      }

      // Enable color transitions only after setting the color (so that we don't transition in to the new color).
      // Do this in a new animation frame so that we don't set the color class and transition class simultaneously
      // (allow repaint first before enabling transitions).
      requestAnimationFrame(() => {
        document.documentElement.classList.add('color-transitions');
      })
    })

    // Delegated handler for the eye-strain toggle: the bound element gets
    // replaced during blog-mode swaps, so a one-shot onclick wouldn't survive.
    document.addEventListener('click', (e) => {
      const t = e.target;
      if (t && t.closest && t.closest('#toggle-eye-strain')) {
        setAlternativeColor();
      }
    });
  </script>
</head>

<body>
  <main class:list={['window', { 'window--post': isPost }]}>
    <header class="window__header">
      <div class="window-buttons">
        <span class="window-buttons__close"></span><span class="window-buttons__min">
        </span><span class="window-buttons__max">
        </span>
      </div>
      <div class="window-title">
        <h1>{windowTitle ?? title}</h1>
      </div>
    </header>
    <div class="window__body">
      <aside>
        <slot name="sidebar">
          <Nav />
        </slot>
      </aside>
      <article>
        {!isPost && (
          <div class="body__line-numbers">
            {Array.from({ length: 300 }, (_, i) => (
              <>{i + 1}<br /></>
            ))}
          </div>
        )}
        <div class:list={['body__content', { 'body__content--post': isPost }]}>
          <slot />
        </div>
        <br>
      </article>
    </div>
  </main>

  <script>
    import '../scripts/blogTransitions';
  </script>

</body>

</html>
